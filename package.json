{
  "name": "listening-tool",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/download-models.js",
    "build": "next build",
    "start": "next start",
    "lint": "next lint .",
    "lint:fix": "next lint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
